# 前端可访问的环境变量（NEXT_PUBLIC_ 前缀，用于浏览器端的功能如本地知识库）

# DeepSeek API 密钥
NEXT_PUBLIC_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DeepSeek API 地址
NEXT_PUBLIC_DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
# DeepSeek 默认模型
NEXT_PUBLIC_DEEPSEEK_DEFAULT_MODEL=deepseek-v4-pro
# Ali API 密钥
NEXT_PUBLIC_ALI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Ali API 地址
NEXT_PUBLIC_ALI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Ali 默认模型
NEXT_PUBLIC_ALI_DEFAULT_MODEL=qwen3.7-plus
# Ali 向量模型
NEXT_PUBLIC_ALI_EMBEDDING_MODEL=text-embedding-v3

# 云端知识库管理员密码
CLOUD_KB_PASSWORD=xxxxx